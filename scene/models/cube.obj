v -1.000000  1.000000  1.000000
v -1.000000 -1.000000  1.000000
v  1.000000 -1.000000  1.000000
v  1.000000  1.000000 -1.000000
v -1.000000  1.000000 -1.000000
v -1.000000 -1.000000 -1.000000
v  1.000000 -1.000000 -1.000000

# Materials (simple per-face colors via usemtl)
